{
  "server": {
    "port": 80,
    "name": "HttpServer",
    "threads": 4,
    "log_level": "INFO",
    "shutdown_timeout_ms": 30000
  },
  "logging": {
    "level": "INFO",
    "file": "server.log"
  },
  "redis": {
    "host": "redis",
    "port": 6379,
    "pool_size": 5
  },
  "mysql": {
    "host": "tcp://mysql:3306",
    "user": "",
    "password": "",
    "database": "inference_platform",
    "pool_size": 10
  },
  "models": {
    "labels_path": "models/imagenet_classes.txt",
    "engines": {
      "resnet50": {
        "type": "onnx",
        "path": "models/resnet50_classification.onnx"
      },
      "resnet50_trt": {
        "type": "tensorrt",
        "path": "models/resnet50_classification.engine"
      },
      "resnet50_int8": {
        "type": "tensorrt",
        "path": "models/resnet50_int8.engine"
      }
    }
  },
  "batching": {
    "enabled": false,
    "max_batch_size": 8,
    "max_delay_ms": 10
  },
  "dynamic_engines": []
}
